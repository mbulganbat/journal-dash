# Copy to .env (gitignored) and fill in real values.
# Clerk Publishable Key only — the frontend NEVER needs the Secret Key.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project URL + publishable key (Dashboard → Settings → API Keys).
# Publishable key only — never the secret/service_role key.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx
